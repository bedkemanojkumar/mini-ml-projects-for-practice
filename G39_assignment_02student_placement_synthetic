      "cell_type": "code",
      "source": [
        "# Feature addition of technical_score\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "# STEP 0: SIMULATE DATASET (replace this with your actual CSV)\n",
        "\n",
        "np.random.seed(42)\n",
        "n = 100000\n",
        "\n",
        "branches = ['CSE', 'ECE', 'ME', 'CE', 'EE', 'IT', 'AIDS', 'CSBS']\n",
        "tiers = ['Tier 1', 'Tier 2', 'Tier 3']\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    'branch':                   np.random.choice(branches, n),\n",
        "    'college_tier':             np.random.choice(tiers, n),\n",
        "    'cgpa':                     np.round(np.random.uniform(5.0, 10.0, n), 2),\n",
        "    'backlogs':                 np.random.randint(0, 5, n),\n",
        "    'coding_skills':            np.round(np.random.uniform(1, 10, n), 2),\n",
        "    'dsa_score':                np.round(np.random.uniform(1, 10, n), 2),\n",
        "    'aptitude_score':           np.round(np.random.uniform(1, 10, n), 2),\n",
        "    'communication_skills':     np.round(np.random.uniform(1, 10, n), 2),\n",
        "    'ml_knowledge':             np.round(np.random.uniform(1, 10, n), 2),\n",
        "    'system_design':            np.round(np.random.uniform(1, 10, n), 2),\n",
        "    'internships':              np.random.randint(0, 4, n),\n",
        "    'projects_count':           np.random.randint(0, 10, n),\n",
        "    'certifications':           np.random.randint(0, 6, n),\n",
        "    'hackathons':               np.random.randint(0, 5, n),\n",
        "    'open_source_contributions':np.random.randint(0, 5, n),\n",
        "    'extracurriculars':         np.random.randint(0, 5, n),\n",
        "    'placement_status':         np.random.randint(0, 2, n),\n",
        "    'salary_package_lpa':       np.round(np.random.uniform(3.0, 30.0, n), 2),\n",
        "})\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"DATASET LOADED SUCCESSFULLY\")\n",
        "print(\"=\" * 60)\n",
        "print(f\"Shape: {df.shape}\")\n",
        "print(df.head(3))\n",
        "\n",
        "# STEP 1: CREATE technical_score FEATURE\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"STEP 1: CREATING technical_score (Weighted Composite)\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "weights = {\n",
        "    'coding_skills': 0.30,\n",
        "    'dsa_score':     0.30,\n",
        "    'ml_knowledge':  0.20,\n",
        "    'system_design': 0.20,\n",
        "}\n",
        "\n",
        "print(\"\\nWeights Assigned:\")\n",
        "for feature, weight in weights.items():\n",
        "    print(f\"  {feature:<25} --> {weight} ({int(weight*100)}%)\")\n",
        "\n",
        "df['technical_score'] = (\n",
        "    df['coding_skills']  * weights['coding_skills'] +\n",
        "    df['dsa_score']      * weights['dsa_score']     +\n",
        "    df['ml_knowledge']   * weights['ml_knowledge']  +\n",
        "    df['system_design']  * weights['system_design']\n",
        ")\n",
        "\n",
        "print(\"\\nFormula Applied:\")\n",
        "print(\"  technical_score = coding_skills*0.30 + dsa_score*0.30 + ml_knowledge*0.20 + system_design*0.20\")\n",
        "print(f\"\\nSample values:\\n{df['technical_score'].head(5).to_string()}\")\n",
        "\n",
        "# STEP 2: BASIC SANITY CHECK\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"STEP 2: BASIC SANITY CHECK — describe()\")\n",
        "print(\"=\" * 60)\n",
        "print(df['technical_score'].describe().round(4))\n",
        "\n",
        "\n",
        "# STEP 3: CORRELATION WITH TARGETS\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"STEP 3: CORRELATION WITH TARGET VARIABLES\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "corr_matrix = df[['technical_score', 'placement_status', 'salary_package_lpa']].corr()\n",
        "print(corr_matrix.round(4))\n",
        "\n",
        "# STEP 4: COMPARE INDIVIDUAL FEATURES VS COMPOSITE\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"STEP 4: INDIVIDUAL FEATURES vs technical_score\")\n",
        "print(\"        Correlation with placement_status\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "feature_cols = ['coding_skills', 'dsa_score', 'ml_knowledge', 'system_design', 'technical_score']\n",
        "corr_with_target = df[feature_cols + ['placement_status']].corr()['placement_status'].drop('placement_status').sort_values(ascending=False)\n",
        "print(corr_with_target.round(4).to_string())\n",
        "\n",
        "# ============================================================\n",
        "# STEP 5: MEAN technical_score BY PLACEMENT STATUS\n",
        "# ============================================================\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"STEP 5: MEAN technical_score — Placed vs Not Placed\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "mean_by_status = df.groupby('placement_status')['technical_score'].mean().round(4)\n",
        "mean_by_status.index = mean_by_status.index.map({0: 'Not Placed (0)', 1: 'Placed (1)'})\n",
        "print(mean_by_status.to_string())\n",
        "\n",
        "diff = mean_by_status['Placed (1)'] - mean_by_status['Not Placed (0)']\n",
        "print(f\"\\nDifference (Placed - Not Placed): {diff:.4f}\")\n",
        "\n",
        "# ============================================================\n",
        "# STEP 6: VISUALIZATIONS\n",
        "# ============================================================\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"STEP 6: GENERATING VISUALIZATIONS...\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(15, 11))\n",
        "fig.suptitle('technical_score — Feature Engineering Validation', fontsize=16, fontweight='bold', y=1.01)\n",
        "\n",
        "# --- Plot 1: Distribution of technical_score ---\n",
        "ax1 = axes[0, 0]\n",
        "ax1.hist(df['technical_score'], bins=60, color='steelblue', edgecolor='white', alpha=0.85)\n",
        "ax1.axvline(df['technical_score'].mean(), color='red', linestyle='--', linewidth=1.8, label=f\"Mean: {df['technical_score'].mean():.2f}\")\n",
        "ax1.set_title('Distribution of technical_score', fontsize=13, fontweight='bold')\n",
        "ax1.set_xlabel('technical_score')\n",
        "ax1.set_ylabel('Count')\n",
        "ax1.legend()\n",
        "\n",
        "# --- Plot 2: technical_score by Placement Status (KDE) ---\n",
        "ax2 = axes[0, 1]\n",
        "for status, label, color in [(0, 'Not Placed', 'tomato'), (1, 'Placed', 'mediumseagreen')]:\n",
        "    subset = df[df['placement_status'] == status]['technical_score']\n",
        "    ax2.hist(subset, bins=50, alpha=0.55, label=label, color=color, edgecolor='white', density=True)\n",
        "ax2.set_title('technical_score by Placement Status', fontsize=13, fontweight='bold')\n",
        "ax2.set_xlabel('technical_score')\n",
        "ax2.set_ylabel('Density')\n",
        "ax2.legend()\n",
        "\n",
        "# --- Plot 3: Correlation Bar Chart ---\n",
        "ax3 = axes[1, 0]\n",
        "colors = ['gold' if f == 'technical_score' else 'cornflowerblue' for f in corr_with_target.index]\n",
        "bars = ax3.barh(corr_with_target.index, corr_with_target.values, color=colors, edgecolor='white')\n",
